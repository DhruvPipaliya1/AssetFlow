// AssetFlow — Prisma schema (implements docs/ARCHITECTURE.md §6)
// Hard-guarantee constraints (partial unique index, booking EXCLUDE, tag sequence)
// live in a raw-SQL migration — Prisma can't express them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECH_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  PLANNED
  IN_PROGRESS
  CLOSED
}

enum AuditItemStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum AuditScopeType {
  DEPARTMENT
  LOCATION
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─────────────────────────── Models ───────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  status       Status   @default(ACTIVE)
  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  createdAt    DateTime @default(now())

  // back-relations (each FK into User needs a named relation)
  headedDepartments   Department[]         @relation("DepartmentHead")
  heldAssets          Asset[]              @relation("AssetCurrentHolder")
  allocationsReceived Allocation[]         @relation("AllocationToUser")
  allocationsMade     Allocation[]         @relation("AllocationByUser")
  transfersFrom       TransferRequest[]    @relation("TransferFrom")
  transfersTo         TransferRequest[]    @relation("TransferTo")
  transfersRequested  TransferRequest[]    @relation("TransferRequestedBy")
  transfersApproved   TransferRequest[]    @relation("TransferApprovedBy")
  bookings            Booking[]            @relation("BookingBy")
  maintenanceRaised   MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceApproved MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  maintenanceAssigned MaintenanceRequest[] @relation("MaintenanceTechnician")
  auditCyclesCreated  AuditCycle[]         @relation("AuditCycleCreatedBy")
  auditAssignments    AuditAssignment[]    @relation("AuditAssignmentAuditor")
  auditItemsAudited   AuditItem[]          @relation("AuditItemAuditedBy")
  notifications       Notification[]       @relation("NotificationUser")
  activityLogs        ActivityLog[]        @relation("ActivityActor")

  @@index([role])
  @@index([departmentId])
}

model Department {
  id                 String   @id @default(cuid())
  name               String
  status             Status   @default(ACTIVE)
  headUserId         String?
  headUser           User?    @relation("DepartmentHead", fields: [headUserId], references: [id])
  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")
  createdAt          DateTime @default(now())

  members     User[]       @relation("DepartmentMembers")
  ownedAssets Asset[]      @relation("AssetOwnerDepartment")
  allocations Allocation[] @relation("AllocationToDepartment")
  bookings    Booking[]    @relation("BookingOnBehalfOfDepartment")
}

model AssetCategory {
  id           String   @id @default(cuid())
  name         String
  customFields Json?    // e.g. { "warrantyMonths": 24 }
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())

  assets Asset[]
}

model Asset {
  id                  String      @id @default(cuid())
  name                String
  assetTag            String      @unique // AF-0001
  serialNumber        String?
  categoryId          String
  category            AssetCategory @relation(fields: [categoryId], references: [id])
  acquisitionDate     DateTime?
  acquisitionCost     Decimal?    @db.Decimal(12, 2) // ranking/reports only — NOT accounting
  condition           String?
  location            String?
  status              AssetStatus @default(AVAILABLE)
  isBookable          Boolean     @default(false)
  photoUrl            String?
  documents           Json?
  currentHolderUserId String?
  currentHolderUser   User?       @relation("AssetCurrentHolder", fields: [currentHolderUserId], references: [id])
  ownerDepartmentId   String?
  ownerDepartment     Department? @relation("AssetOwnerDepartment", fields: [ownerDepartmentId], references: [id])
  createdAt           DateTime    @default(now())

  allocations Allocation[]
  transfers   TransferRequest[]
  bookings    Booking[]
  maintenance MaintenanceRequest[]
  auditItems  AuditItem[]

  @@index([status])
  @@index([categoryId])
  @@index([ownerDepartmentId])
}

model Allocation {
  id                      String     @id @default(cuid())
  assetId                 String
  asset                   Asset      @relation(fields: [assetId], references: [id])
  allocatedToUserId       String?
  allocatedToUser         User?      @relation("AllocationToUser", fields: [allocatedToUserId], references: [id])
  allocatedToDepartmentId String?
  allocatedToDepartment   Department? @relation("AllocationToDepartment", fields: [allocatedToDepartmentId], references: [id])
  allocatedByUserId       String
  allocatedByUser         User       @relation("AllocationByUser", fields: [allocatedByUserId], references: [id])
  allocatedAt             DateTime   @default(now())
  expectedReturnDate      DateTime?
  returnedAt              DateTime?
  returnCondition         String?
  checkInNotes            String?
  status                  AllocationStatus @default(ACTIVE)

  // NOTE: a partial unique index (one ACTIVE allocation per asset) is added
  // via raw-SQL migration — Prisma cannot express partial unique indexes.
  @@index([assetId])
  @@index([status])
  @@index([allocatedToUserId])
}

model TransferRequest {
  id                String   @id @default(cuid())
  assetId           String
  asset             Asset    @relation(fields: [assetId], references: [id])
  fromUserId        String?
  fromUser          User?    @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUserId          String
  toUser            User     @relation("TransferTo", fields: [toUserId], references: [id])
  requestedByUserId String
  requestedByUser   User     @relation("TransferRequestedBy", fields: [requestedByUserId], references: [id])
  approvedByUserId  String?
  approvedByUser    User?    @relation("TransferApprovedBy", fields: [approvedByUserId], references: [id])
  status            TransferStatus @default(REQUESTED)
  decidedAt         DateTime?
  createdAt         DateTime @default(now())

  @@index([assetId])
  @@index([status])
}

model Booking {
  id                     String   @id @default(cuid())
  assetId                String
  asset                  Asset    @relation(fields: [assetId], references: [id])
  bookedByUserId         String
  bookedByUser           User     @relation("BookingBy", fields: [bookedByUserId], references: [id])
  onBehalfOfDepartmentId String?
  onBehalfOfDepartment   Department? @relation("BookingOnBehalfOfDepartment", fields: [onBehalfOfDepartmentId], references: [id])
  startTime              DateTime
  endTime                DateTime
  status                 BookingStatus @default(UPCOMING)
  createdAt              DateTime @default(now())

  // NOTE: a GiST EXCLUDE constraint (no overlapping tsrange per asset for
  // non-cancelled bookings) is added via raw-SQL migration.
  @@index([assetId, startTime])
  @@index([status])
}

model MaintenanceRequest {
  id               String   @id @default(cuid())
  assetId          String
  asset            Asset    @relation(fields: [assetId], references: [id])
  raisedByUserId   String
  raisedByUser     User     @relation("MaintenanceRaisedBy", fields: [raisedByUserId], references: [id])
  description      String
  priority         Priority @default(MEDIUM)
  photoUrl         String?
  status           MaintenanceStatus @default(PENDING)
  approvedByUserId String?
  approvedByUser   User?    @relation("MaintenanceApprovedBy", fields: [approvedByUserId], references: [id])
  technicianUserId String?
  technicianUser   User?    @relation("MaintenanceTechnician", fields: [technicianUserId], references: [id])
  createdAt        DateTime @default(now())
  resolvedAt       DateTime?

  @@index([assetId])
  @@index([status])
}

model AuditCycle {
  id              String   @id @default(cuid())
  name            String
  scopeType       AuditScopeType
  scopeValue      String
  startDate       DateTime
  endDate         DateTime
  status          AuditCycleStatus @default(PLANNED)
  createdByUserId String
  createdByUser   User     @relation("AuditCycleCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  auditors AuditAssignment[]
  items    AuditItem[]
}

model AuditAssignment {
  id            String     @id @default(cuid())
  auditCycleId  String
  auditCycle    AuditCycle @relation(fields: [auditCycleId], references: [id])
  auditorUserId String
  auditorUser   User       @relation("AuditAssignmentAuditor", fields: [auditorUserId], references: [id])

  @@unique([auditCycleId, auditorUserId])
}

model AuditItem {
  id              String     @id @default(cuid())
  auditCycleId    String
  auditCycle      AuditCycle @relation(fields: [auditCycleId], references: [id])
  assetId         String
  asset           Asset      @relation(fields: [assetId], references: [id])
  status          AuditItemStatus @default(PENDING)
  auditedByUserId String?
  auditedByUser   User?      @relation("AuditItemAuditedBy", fields: [auditedByUserId], references: [id])
  notes           String?
  auditedAt       DateTime?

  @@unique([auditCycleId, assetId])
  @@index([status])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("NotificationUser", fields: [userId], references: [id])
  type       String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorUserId String
  actorUser   User     @relation("ActivityActor", fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
}
